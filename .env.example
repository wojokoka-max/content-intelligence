# --- AI Diagnosis Engine (BYOK) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Search Console ---
# OAuth 2.0 access token with https://www.googleapis.com/auth/webmasters.readonly scope.
# In production, replace with a full OAuth flow or a service account.
GSC_ACCESS_TOKEN=
GSC_SITE_URL=https://lowstylelife.art/

# --- Mode ---
# When "true" (or when GSC_ACCESS_TOKEN is empty), the app runs on deterministic demo data.
DEMO_MODE=true
